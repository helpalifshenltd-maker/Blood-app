SUPABASE_PUBLISHABLE_KEY=sb_publishable_vNUUU1OamY9SExJb78MoCQ_CwmyEu5e

# SUPABASE_SECRET_KEY: The secret/service-role key of your Supabase project.
SUPABASE_SECRET_KEY=sb_secret_nJK_pDmRl3KsEDPprph3iw_7W-HcUuG

# SUPABASE_JWKS_URL: JWKS URL for Auth token verification.
